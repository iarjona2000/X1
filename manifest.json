{
  "manifest_version": 3,
  "name": "System X1",
  "version": "3.0.4",
  "description": "Browser agent con voz + texto. Sin API keys. Navega, busca, gestiona email/calendario, ejecuta tareas multi-paso.",
  "key": "",
  "permissions": [
    "identity",
    "storage",
    "tabs",
    "tabGroups",
    "alarms",
    "scripting",
    "notifications",
    "offscreen",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://calendar.google.com/*",
    "https://docs.google.com/*",
    "https://sheets.google.com/*",
    "https://drive.google.com/*",
    "https://www.googleapis.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "oauth2": {
    "client_id": "653077619345-erf587evo9le3t8p9ku5i8t485rdo6lc.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.compose",
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/calendar.events",
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/drive.readonly",
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/tasks",
      "https://www.googleapis.com/auth/contacts.readonly"
    ]
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content/calendar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content/docs.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sheets.google.com/*"],
      "js": ["content/sheets.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/meet.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*", "https://teams.microsoft.com/*"],
      "js": ["content/meeting-transcription.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*"],
      "js": ["content/universal.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/voice-listener.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/floating-toolbar.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/pointer-interaction.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["background/protocol.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content/voice-bridge.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://drive.google.com/*"],
      "js": ["content/drive.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://contacts.google.com/*"],
      "js": ["content/contacts.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "action": {
    "default_icon": "assets/icon-128.png",
    "default_title": "Abrir X1"
  }
}
