{
  "name": "x1-sidepanel-ui",
  "version": "1.0.0",
  "private": true,
  "description": "X1 side panel — Fluent 2 UI (React v9). Builds into ../sidepanel/dist/panel-ui.js",
  "scripts": {
    "build": "esbuild src/main.jsx --bundle --minify --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\" --outfile=../sidepanel/dist/panel-ui.js",
    "dev": "esbuild src/main.jsx --bundle --jsx=automatic --define:process.env.NODE_ENV=\\\"development\\\" --outfile=../sidepanel/dist/panel-ui.js --watch"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "@primer/react": "^38.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
