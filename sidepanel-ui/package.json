{
  "name": "x1-sidepanel-ui",
  "version": "1.0.0",
  "private": true,
  "description": "X1 side panel — Fluent 2 UI (React v9). Builds into ../sidepanel/dist/panel-ui.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i src/index.css -o ../sidepanel/dist/panel-ui-2026.css --minify",
    "build:js": "esbuild src/main.jsx --bundle --minify --jsx=automatic --loader:.woff2=file --define:process.env.NODE_ENV=\\\"production\\\" --outfile=../sidepanel/dist/panel-ui-2026.js",
    "build": "npm run build:css && npm run build:js",
    "dev:css": "npx @tailwindcss/cli -i src/index.css -o ../sidepanel/dist/panel-ui-2026.css --watch",
    "dev:js": "esbuild src/main.jsx --bundle --jsx=automatic --loader:.woff2=file --define:process.env.NODE_ENV=\\\"development\\\" --outfile=../sidepanel/dist/panel-ui-2026.js --watch",
    "dev": "npm run dev:css & npm run dev:js"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.54.0",
    "@fluentui/react-icons": "^2.0.245",
    "@primer/octicons-react": "^19.29.1",
    "@primer/react": "^38.30.0",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "postcss": "^8.5.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "postcss-cli": "^11.0.1"
  }
}
